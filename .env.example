# Hermes Web UI -- local machine config template
# Copy this to .env and fill in your values.
# start.sh sources .env automatically if present.
# All values are optional -- auto-discovery will fill in anything left blank.

# Path to your hermes-agent checkout (the repo that contains run_agent.py)
# HERMES_WEBUI_AGENT_DIR=/path/to/hermes-agent

# Python executable to use (defaults to the agent venv if found)
# HERMES_WEBUI_PYTHON=/path/to/python

# Bind address (default: 127.0.0.1 -- loopback only, safe default)
# HERMES_WEBUI_HOST=127.0.0.1

# Port to listen on (default: 8787)
# HERMES_WEBUI_PORT=8787

# Where to store sessions, workspaces, and other state (default: ~/.hermes/webui-mvp)
# HERMES_WEBUI_STATE_DIR=~/.hermes/webui

# Default workspace directory shown on first launch
# HERMES_WEBUI_DEFAULT_WORKSPACE=~/workspace

# Base directory for all Hermes state (affects all paths above if set)
# HERMES_HOME=~/.hermes

# Path to your Hermes config.yaml (for toolsets and model config)
# HERMES_CONFIG_PATH=~/.hermes/config.yaml

# Display name for the assistant in the UI (default: 云千易)
# HERMES_WEBUI_BOT_NAME=云千易

# 不使用 Hermes 网关时设为 1，可关闭「网关心跳失败」横幅（仍可通过 /api/health/agent 查询）
# HERMES_WEBUI_DISABLE_AGENT_HEALTH=1

# ERP SSO (required for /api/auth/sso-login)
# ERP_BASE_URL=https://your-erp-host/path
# ERP_APP_ID=your-app-id
# ERP_APP_SECRET=your-app-secret
# ERP_APPLICATION_ID=your-application-id
# ERP_TIMEOUT_SECONDS=10
# HERMES_WEBUI_SAAS=1
# SaaS：租户目录无 LLM 配置时，指定主机共用的 Hermes 根目录（含 config.yaml / .env）
# 在 SaaS 多租户模式下，所有用户共享同一个 LLM 模型配置（包括 vision、title_generation 等辅助任务）
# 视觉模型等辅助任务的配置应该在此共享目录的 config.yaml 中设置，例如：
#   auxiliary:
#     vision:
#       provider: openai
#       model: gpt-4o
#     title_generation:
#       provider: openai
#       model: gpt-4o-mini
# HERMES_WEBUI_SHARED_HERMES_HOME=~/.hermes

# 服务端 Python logging 级别（默认 WARNING；要看 workCode / api.auth 的 info 日志请设为 INFO）
# HERMES_WEBUI_LOG_LEVEL=INFO
